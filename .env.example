# ──────────────────────────────────────────────────────────────────────────────
# HOMEBUDDY-12 ENVIRONMENT VARIABLES (CLOUDFLARE/PRODUCTION TEMPLATE)
# ──────────────────────────────────────────────────────────────────────────────

# ─── APP URLS ───
# Frontend URL
NEXT_PUBLIC_APP_URL=https://www.homefixu.in
# NEXT_PUBLIC_APP_URL=http://localhost:3001

# Backend URL
NEXT_PUBLIC_SERVER_URL=https://api.homefixu.in
# NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ─── AUTHENTICATION ───
# Better Auth Secret (Generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=your_secret_here
# Better Auth URL (Should be NEXT_PUBLIC_SERVER_URL/api/auth)
BETTER_AUTH_URL=https://api.homefixu.in/api/auth
# BETTER_AUTH_URL=http://localhost:3000/api/auth

# Cookie Domain (Use "homefixu.in" for production, "localhost" for local dev)
COOKIE_DOMAIN=homefixu.in
# COOKIE_DOMAIN=localhost

# ─── DATABASE (NEON) ───
DATABASE_URL=postgresql://user:password@neon-host/neondb?sslmode=require

# ─── GOOGLE OAUTH (OPTIONAL) ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── NODE ENVIRONMENT ───
NODE_ENV=development
