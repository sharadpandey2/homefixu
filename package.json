{
  "name": "homebuddy-12",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:cf": "turbo build && pnpm --filter web run build:cf",
    "deploy:web": "wrangler deploy -c apps/web/wrangler.jsonc",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @homebuddy-12/db db:push",
    "db:studio": "turbo -F @homebuddy-12/db db:studio",
    "db:generate": "turbo -F @homebuddy-12/db db:generate",
    "db:migrate": "turbo -F @homebuddy-12/db db:migrate",
    "check": "biome check --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@homebuddy-12/env": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "catalog:",
    "lucide-react": "^1.8.0",
    "tailwind-merge": "^3.5.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@cloudflare/workers-types": "catalog:",
    "@homebuddy-12/config": "workspace:*",
    "@types/bull": "^4.10.4",
    "@types/node": "^22.13.14",
    "@types/nodemailer": "^8.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "turbo": "^2.6.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:",
    "wrangler": "^4.76.0"
  },
  "packageManager": "pnpm@10.32.1",
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write ."
    ]
  }
}
